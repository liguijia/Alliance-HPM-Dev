#!/usr/bin/env bash

# ------------------------------------------------------------
# Safe shell options (NO nounset to avoid vendor script crash)
# ------------------------------------------------------------
set -e

# ------------------------------------------------------------
# 0) Compatibility fix for HPM env.sh
# Their script reads $MSYSTEM without guarding.
# ------------------------------------------------------------
: "${MSYSTEM:=}"

# ------------------------------------------------------------
# 1) Load official HPM SDK environment
# ------------------------------------------------------------
SDK_DIR="/workspace/hpm_sdk"
ENV_SH="${SDK_DIR}/env.sh"

if [ ! -f "$ENV_SH" ]; then
  echo "[envrc] ERROR: $ENV_SH not found"
  return 1
fi

# shellcheck disable=SC1090
source "$ENV_SH"

# ------------------------------------------------------------
# 2) Toolchain configuration (your container provides toolchain)
# ------------------------------------------------------------
export GNURISCV_TOOLCHAIN_PATH=/opt/riscv32-gnu-toolchain-elf-bin
export PATH="$GNURISCV_TOOLCHAIN_PATH/bin:$PATH"
export PATH="/workspace/tools/scripts:$PATH"

# IMPORTANT:
# Many HPM CMake scripts require this explicitly
export HPM_SDK_TOOLCHAIN_VARIANT=

# ------------------------------------------------------------
# 3) Python virtual environment (workspace-local)
# ------------------------------------------------------------
VENV_DIR="/workspace/.venv"
REQ_FILE="$HPM_SDK_BASE/scripts/requirements.txt"

if ! command -v python3 >/dev/null 2>&1; then
  echo "[envrc] ERROR: python3 not found"
  return 1
fi

# Create venv if missing
if [ ! -x "$VENV_DIR/bin/python" ]; then
  echo "[envrc] Creating venv at $VENV_DIR ..."
  python3 -m venv "$VENV_DIR"
fi

# Activate venv
# shellcheck disable=SC1090
source "$VENV_DIR/bin/activate"

# Upgrade pip tooling quietly
python -m pip install -U pip setuptools wheel >/dev/null

# Install SDK requirements (only if needed)
FLAG="$VENV_DIR/.installed_flag"

if [ -f "$REQ_FILE" ]; then
  if [ ! -f "$FLAG" ] || [ "$REQ_FILE" -nt "$FLAG" ]; then
    echo "[envrc] Installing python deps..."
    pip install -r "$REQ_FILE"
    touch "$FLAG"
  fi
else
  echo "[envrc] WARNING: requirements file missing: $REQ_FILE"
fi

# ------------------------------------------------------------
# 5) OpenOCD (prefer HPM prebuilt; fallback to local build)
# ------------------------------------------------------------

# HPM prebuilt OpenOCD
HPM_OPENOCD_PREFIX="/workspace/tools/openocd-hpm/install"
# Your locally built OpenOCD fallback
LOCAL_OPENOCD_PREFIX="/workspace/tools/openocd-build/install"

# HPM SDK OpenOCD config root (contains probes/ boards/ soc/)
export HPM_OCD_SCRIPTS="${SDK_DIR}/boards/openocd"

if [ -x "${HPM_OPENOCD_PREFIX}/bin/openocd" ]; then
  export PATH="${HPM_OPENOCD_PREFIX}/bin:$PATH"
  export OPENOCD_SCRIPTS="${HPM_OPENOCD_PREFIX}/share/openocd/scripts"
  echo "[envrc] OpenOCD=HPM prebuilt: ${HPM_OPENOCD_PREFIX}/bin/openocd"
elif [ -x "${LOCAL_OPENOCD_PREFIX}/bin/openocd" ]; then
  export PATH="${LOCAL_OPENOCD_PREFIX}/bin:$PATH"
  export OPENOCD_SCRIPTS="${LOCAL_OPENOCD_PREFIX}/share/openocd/scripts"
  echo "[envrc] OpenOCD=local build: ${LOCAL_OPENOCD_PREFIX}/bin/openocd"
else
  echo "[envrc] OpenOCD not found (optional)."
fi

# ------------------------------------------------------------
# 6) J-Link (auto-detect installed version under /workspace/tools)
# ------------------------------------------------------------
JLINK_ROOT=""
for d in /workspace/tools/jlink-*/install; do
  if [ -x "$d/JLinkExe" ]; then
    JLINK_ROOT="$d"
    break
  fi
done

if [ -n "$JLINK_ROOT" ]; then
  export JLINK_ROOT
  export PATH="$JLINK_ROOT:$PATH"
  export LD_LIBRARY_PATH="$JLINK_ROOT:${LD_LIBRARY_PATH:-}"
  echo "[envrc] J-Link enabled: $JLINK_ROOT/JLinkExe"
else
  echo "[envrc] J-Link not found (optional)."
fi
